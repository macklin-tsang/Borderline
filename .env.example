# Database
DB_URL=jdbc:postgresql://postgres:5432/borderline
DB_USERNAME=borderline
DB_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=changeme
JWT_EXPIRY_MS=86400000

# API Key HMAC (generate with: openssl rand -base64 32)
# Store the production value in AWS Secrets Manager — never commit the real secret
HMAC_SECRET=changeme
HMAC_KEY_VERSION=1

# GeoIP service
GEOIP_URL=http://geoip:8001

# MaxMind (required in prod — sign up at maxmind.com)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
