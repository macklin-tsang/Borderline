# ============================================================
# Borderline — environment variable reference
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DB_USERNAME=borderline
DB_PASSWORD=changeme              # Use a strong password in production

# --- Redis ---
# (REDIS_HOST / REDIS_PORT are hard-coded to service names in docker-compose.yml)

# --- JWT ---
# Generate: openssl rand -base64 64
# Minimum 512-bit (64 byte) secret recommended for HS512.
JWT_SECRET=changeme
JWT_EXPIRY_MS=86400000            # 24 hours in milliseconds

# --- API Key HMAC ---
# Generate: openssl rand -base64 32
# Store the production value in a secrets manager (AWS Secrets Manager, Vault).
# Changing this value invalidates ALL existing API keys — rotate carefully.
HMAC_SECRET=changeme
HMAC_KEY_VERSION=1

